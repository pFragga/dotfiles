#!/bin/sh
#
# ~/.aliasrc
# Shell aliases.

# Run as root
alias pacman="sudo pacman"
alias sv="sudo nvim"
alias sr="sudo ranger"

# Add color
alias ls="ls -hN --color=auto --group-directories-first"
alias grep="grep --color=auto"
alias ip="ip -c=auto"
alias diff="diff --color"
alias watch="watch -c"

# Verbose output
alias mv="mv -v"
alias cp="cp -v"
alias rm="rm -fv"
alias mkd="mkdir -v"
alias chmod="chmod -v"
alias ln="ln -v"
alias pkill="pkill -e"
alias killall="killall -v"
alias stow="stow -v"

# Human readable output
alias lsblk="lsblk -p"
alias df="df -h"
alias du="du -h"

# Abbreviations
alias ll="ls -l"
alias v="nvim"
alias vim="nvim"
alias r="ranger"
alias pm="pulsemixer"
alias nc="ncmpcpp"
alias nf="clear && neofetch"

# Edit configuration files on the fly
alias cfa="v $HOME/.aliasrc"
alias cfb="v $HOME/.bashrc"
alias cfv="v $XDG_CONFIG_HOME/nvim/init.vim"
alias cfr="v $XDG_CONFIG_HOME/ranger/rc.conf"
alias cfp="v $XDG_CONFIG_HOME/picom/picom.conf"
alias cfn="v $XDG_CONFIG_HOME/ncmpcpp/config"
alias cfz="v $XDG_CONFIG_HOME/zathura/zathurarc"
alias cfd="v $XDG_CONFIG_HOME/dunst/dunstrc"
alias cfs="v $XDG_CONFIG_HOME/sxhkd/sxhkdrc"
alias cfx="v $XDG_CONFIG_HOME/X11/"
alias cff="v $XDG_CONFIG_HOME/fontconfig/fonts.conf"

# Directory shortcuts
alias srcm="cd $HOME/.local/src/dmenu && ls"
alias srcd="cd $HOME/.local/src/dwm && ls"
alias srcs="cd $HOME/.local/src/st && ls"
alias srcl="cd $HOME/.local/src/slock && ls"
alias srcsl="cd $HOME/.local/src/slstatus && ls"
alias aueb="cd $HOME/dox/AUEB/Semesters"

# Git
alias gs="git status"

# Etc
alias wget="wget --hsts-file=$XDG_DATA_HOME/wget-hsts"
